{
    "name": "alex/ask-wp",
    "description": "Query your WordPress content in plain English.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10"
    },
    "autoload": {
        "psr-4": {
            "AskWP\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AskWP\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
